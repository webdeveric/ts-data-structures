{
  "entryPoints": ["src/*.ts"],
  "out": "docs",
  "excludeInternal": true,
  "excludeNotDocumented": true,
  "cleanOutputDir": true,
  "readme": "readme.md",
  "gitRevision": "main",
  "categorizeByGroup": true,
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "sort": ["source-order"],
  "treatWarningsAsErrors": true,
  "validation": {
    "notExported": true,
    "invalidLink": true
  }
}
