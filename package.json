{
  "name": "@webdeveric/ts-data-structures",
  "description": "Data structures written in TypeScript",
  "version": "0.0.0",
  "keywords": [],
  "author": "Eric King <eric@webdeveric.com> (https://webdeveric.com/)",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webdeveric/ts-data-structures.git"
  },
  "bugs": {
    "url": "https://github.com/webdeveric/ts-data-structures/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf ./dist/ ./docs/ ./cache/ ./coverage/",
    "prebuild": "pnpm clean",
    "build": "tsgo --build tsconfig.src.json --force",
    "validate": "validate-package-exports --check --info",
    "postbuild": "pnpm validate",
    "build:docs": "typedoc",
    "typecheck": "tsgo --build --verbose",
    "lint": "eslint ./*.{js,cjs,mjs,ts,cts,mts} ./src/ --ext .ts,.mjs,.cjs",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "spellcheck": "cspell './{.github,src,test}/**/*.{ts,json}' './*.{js,json,md,mjs,mts}' './package.json' --no-progress",
    "prepublishOnly": "pnpm typecheck && pnpm spellcheck && pnpm lint && pnpm coverage && pnpm build",
    "format": "prettier --write ./*.{js,json,md,mjs,mts} ./src/",
    "prepare": "husky"
  },
  "prettier": "@webdeveric/prettier-config",
  "devDependencies": {
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260704.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@webdeveric/eslint-config-ts": "^0.12.1",
    "@webdeveric/prettier-config": "^0.4.0",
    "commitlint": "^21.2.0",
    "commitlint-plugin-cspell": "^0.9.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^10.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "typedoc": "^0.28.19",
    "validate-package-exports": "^1.2.0",
    "vitest": "^4.1.9"
  }
}
