{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": "./src",
    "outDir": "./dist/",
    "sourceMap": false,
    "declarationMap": false,
    "verbatimModuleSyntax": true,
    "tsBuildInfoFile": "./cache/src.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
